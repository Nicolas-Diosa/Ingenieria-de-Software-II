  "item": [
    {
      "name": "FiltrarCOP",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Bogotá es la capital de colombia\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    pm.expect(jsonData.data.countries[0].capital).to.eql(\"Bogotá\");\r",
              "});\r",
              "pm.test(\"El  nomre del país es colombia\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    pm.expect(jsonData.data.countries[0].name).to.eql(\"Colombia\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query {\r\n  countries(filter: { currency: { eq: \"COP\" } }) {\r\n    name\r\n    capital\r\n  }\r\n}\r\n",
            "variables": ""
          }
        },
        "url": {
          "raw": "{{base_URL}}",
          "host": [
            "{{base_URL}}"
          ]
        }
      },
      "response": []
    },
