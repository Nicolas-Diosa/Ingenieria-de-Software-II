          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"El primer país de la lista es Colombia\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    pm.expect(jsonData.data.countries[0].name).to.eql(\"Colombia\");\r",
              "});\r",
              "pm.test(\"Verificar que Argentina está en la lista de países\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    var nombresPaises = jsonData.data.countries[0].continent.countries.map(p => p.name);\r",
              "    \r",
              "    pm.expect(nombresPaises).to.include(\"Argentina\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
